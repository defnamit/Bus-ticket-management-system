def add():
    print("\n")
    pname = input("ENTER THE PASSENGER'S NAME : ")
    pid = input("ENTER PASSENGER'S ID : ")
    start = input("ENTER BOARDING STATION : ")
    stop = input("ENTER DEPARTING STATION : ")
    date = input("ENTER DATE OF TRIP (YYYY-MM-DD) : ")
    fare = int(input("ENTER THE PRICE OF TICKET : "))

    q = "INSERT INTO BUS_LOGS VALUES('{}','{}','{}','{}','{}',{})".format(
        pname, pid, start, stop, date, fare)

    cursor.execute(q)
    mysql.commit()

    print("\nDATA ENTERED SUCCESSFULLY\n")
    i = input("ADD ANOTHER RECORD? (Y/N): ")

    if i.upper() == 'Y':
        add()
    else:
        menu()


def menu():
    print("\n\n MENU ===>")
    print("1. ADD A RECORD")
    print("2. DELETE A RECORD")
    print("3. DISPLAY ALL RECORDS")
    print("4. SEARCH A SPECIFIC RECORD")
    print("5. MODIFY A RECORD")
    print("6. QUIT\n")

    choice = int(input("ENTER YOUR CHOICE : "))

    if choice == 1:
        add()
    elif choice == 2:
        del1()
    elif choice == 3:
        dis()
    elif choice == 4:
        search()
    elif choice == 5:
        modify()
    elif choice == 6:
        print("PROGRAM TERMINATED")
    else:
        print("INVALID CHOICE")
        input("PRESS ENTER TO TRY AGAIN")
        menu()


# Start the program
menu()
