def dis():
    q = "SELECT * FROM BUS_LOGS"
    cursor.execute(q)
    L = cursor.fetchall()

    if len(L) == 0:
        print("TABLE IS EMPTY\n")
    else:
        for a in L:
            print(a)

    input("PRESS ENTER TO CONTINUE\n")
    menu()


