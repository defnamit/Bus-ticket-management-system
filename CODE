    print("4. RETURN TO MENU\n")

    choice1 = int(input("ENTER YOUR CHOICE : "))

    if choice1 == 1:
        i = input("ENTER PASSENGER'S NAME : ")
        q = "DELETE FROM BUS_LOGS WHERE pname='{}'".format(i)

    elif choice1 == 2:
