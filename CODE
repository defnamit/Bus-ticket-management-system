        i = input("ENTER NAME : ")
        q = "SELECT * FROM BUS_LOGS WHERE pname='{}'".format(i)

    elif c == 2:
        i = input("ENTER PASSENGER'S ID : ")
        q = "SELECT * FROM BUS_LOGS WHERE pid='{}'".format(i)

    elif c == 3:
        i = input("ENTER BOARDING STATION: ")
