    print("6. QUIT\n")

    c = int(input("ENTER YOUR CHOICE : "))
    r = input("ENTER THE PASSENGER_ID : ")

    if c == 1:
        i = input("ENTER CORRECTED NAME : ")
        q = "UPDATE BUS_LOGS SET pname='{}' WHERE pid='{}'".format(i, r)

    elif c == 2:
        i = input("ENTER CORRECTED BOARDING STATION: ")
        q = "UPDATE BUS_LOGS SET start='{}' WHERE pid='{}'".format(i, r)

    elif c == 3:
        i = input("ENTER CORRECTED DEPARTING STATION: ")
        q = "UPDATE BUS_LOGS SET stop='{}' WHERE pid='{}'".format(i, r)

    elif c == 4:
        i = input("ENTER CORRECTED DATE OF TRIP : ")
        q = "UPDATE BUS_LOGS SET b_date='{}' WHERE pid='{}'".format(i, r)

